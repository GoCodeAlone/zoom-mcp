{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "ok": { "const": true },
        "data": {
          "type": "object",
          "properties": {
            "transcript": { "type": "string", "description": "Raw VTT transcript content." },
            "format":     { "type": "string", "description": "File format, e.g. 'vtt'." }
          },
          "required": ["transcript"]
        }
      },
      "required": ["ok", "data"]
    },
    {
      "type": "object",
      "properties": {
        "ok": { "const": false },
        "error": {
          "type": "object",
          "properties": {
            "code":        { "type": "string" },
            "message":     { "type": "string" },
            "retry_after": { "type": "integer" }
          },
          "required": ["code", "message"]
        }
      },
      "required": ["ok", "error"]
    }
  ]
}
