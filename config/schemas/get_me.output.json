{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "ok": { "const": true },
        "data": {
          "type": "object",
          "properties": {
            "id":         { "type": "string" },
            "email":      { "type": "string" },
            "first_name": { "type": "string" },
            "last_name":  { "type": "string" },
            "type":       { "type": "integer" }
          },
          "required": ["id", "email"]
        }
      },
      "required": ["ok", "data"]
    },
    {
      "type": "object",
      "properties": {
        "ok": { "const": false },
        "error": {
          "type": "object",
          "properties": {
            "code":        { "type": "string" },
            "message":     { "type": "string" },
            "retry_after": { "type": "integer" }
          },
          "required": ["code", "message"]
        }
      },
      "required": ["ok", "error"]
    }
  ]
}
