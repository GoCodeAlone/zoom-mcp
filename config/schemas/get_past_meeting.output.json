{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "ok": { "const": true },
        "data": {
          "type": "object",
          "properties": {
            "id":         { "type": "string" },
            "topic":      { "type": "string" },
            "start_time": { "type": "string" },
            "end_time":   { "type": "string" },
            "duration":   { "type": "integer" },
            "total_minutes": { "type": "integer" },
            "participants_count": { "type": "integer" }
          },
          "required": ["id"]
        }
      },
      "required": ["ok", "data"]
    },
    {
      "type": "object",
      "properties": {
        "ok": { "const": false },
        "error": {
          "type": "object",
          "properties": {
            "code":        { "type": "string" },
            "message":     { "type": "string" },
            "retry_after": { "type": "integer" }
          },
          "required": ["code", "message"]
        }
      },
      "required": ["ok", "error"]
    }
  ]
}
